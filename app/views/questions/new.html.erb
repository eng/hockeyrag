<% content_for :title, "Hockey Rules Q&A" %>

<div class="page">
  <h1>Hockey Rules Q&amp;A — three approaches</h1>
  <p class="lede">
    Ask any question about the NHL rulebook. We'll answer it three ways
    side-by-side: <strong>Naive</strong> (no rulebook), <strong>Brute Force</strong>
    (the whole rulebook in the prompt), and <strong>RAG</strong>
    (top-3 retrieved chunks). Watch timing, tokens, and cost for each.
  </p>

  <%= form_with model: @question, local: true, class: "ask-form" do |f| %>
    <%= f.text_area :text,
                    placeholder: "How long is a minor penalty?",
                    rows: 3,
                    autofocus: true,
                    required: true %>

    <fieldset class="strategy-picker">
      <legend>RAG chunk library:</legend>

      <label class="strategy-option">
        <%= f.radio_button :rag_strategy, "fixed", checked: true %>
        <span class="strategy-label">
          <strong>Fixed-length</strong>
          <small>500-char windows with 100-char overlap, 655 chunks total. The "just chop it up" baseline.</small>
        </span>
      </label>

      <label class="strategy-option">
        <%= f.radio_button :rag_strategy, "structured" %>
        <span class="strategy-label">
          <strong>Structure-aware</strong>
          <small>Split on rule (H3) headings, title prepended to each chunk, 223 chunks total.</small>
        </span>
      </label>
    </fieldset>

    <button type="submit">Ask</button>
  <% end %>

  <h2>Try one of these:</h2>
  <ul class="sample-questions">
    <li>How long is a minor penalty?</li>
    <li>What is the penalty for using a broken stick?</li>
    <li>How big is the goal crease in metric units?</li>
    <li>What's the difference between icing and offside?</li>
    <li>Can a goalie score a goal?</li>
    <li>Is it legal to use a baseball bat?</li>
    <li>What does Rule 22.1 say?</li>
  </ul>
</div>
