<% content_for :title, "Hockey Rules Q&A" %>

<div class="page" data-controller="sample-question">
  <h1>Hockey Rules Q&amp;A — three approaches</h1>
  <p class="lede">
    Ask any question about the NHL rulebook. We'll answer it three ways
    side-by-side: <strong>Naive</strong> (no rulebook), <strong>Brute Force</strong>
    (the whole rulebook in the prompt), and <strong>RAG</strong>
    (top-3 retrieved chunks). Watch timing, tokens, and cost for each.
  </p>

  <%= form_with model: @question, local: true, class: "ask-form",
                data: { sample_question_target: "form" } do |f| %>
    <%= f.text_area :text,
                    placeholder: "How long is a minor penalty?",
                    rows: 3,
                    autofocus: true,
                    required: true,
                    data: { sample_question_target: "field" } %>

    <fieldset class="strategy-picker">
      <legend>RAG strategy:</legend>

      <label class="strategy-option">
        <%= f.radio_button :rag_strategy, "fixed", checked: true %>
        <span class="strategy-label">
          <strong>Fixed-length chunks</strong>
          <small>500-char windows with 100-char overlap. The "just chop it up" baseline (655 chunks).</small>
        </span>
      </label>

      <label class="strategy-option">
        <%= f.radio_button :rag_strategy, "structured" %>
        <span class="strategy-label">
          <strong>Structure-aware chunks</strong>
          <small>Split on rule (H3) headings; title prepended to each chunk (223 chunks).</small>
        </span>
      </label>

      <label class="strategy-option">
        <%= f.radio_button :rag_strategy, "hybrid" %>
        <span class="strategy-label">
          <strong>Hybrid search</strong>
          <small>Cosine + BM25 keyword search on structured chunks, merged with Reciprocal Rank Fusion.</small>
        </span>
      </label>

      <label class="strategy-option">
        <%= f.radio_button :rag_strategy, "rerank" %>
        <span class="strategy-label">
          <strong>Retrieve-then-rerank</strong>
          <small>Pull cosine top-15, then Claude Haiku picks the best 3. Adds ~1-2s + a few cents.</small>
        </span>
      </label>

      <label class="strategy-option">
        <%= f.radio_button :rag_strategy, "hyde" %>
        <span class="strategy-label">
          <strong>HyDE (hypothetical answer)</strong>
          <small>Ask Haiku for a confident hypothetical answer; embed THAT and search structured chunks.</small>
        </span>
      </label>

      <label class="strategy-option">
        <%= f.radio_button :rag_strategy, "large_embedding" %>
        <span class="strategy-label">
          <strong>Larger embedding model</strong>
          <small>Same structure-aware chunks re-embedded with text-embedding-3-large (3072 dims, ~6× cost).</small>
        </span>
      </label>

      <label class="strategy-option strategy-option-recommended">
        <%= f.radio_button :rag_strategy, "hybrid_rerank" %>
        <span class="strategy-label">
          <strong>Hybrid + Rerank <span class="strategy-recommended-tag">★ recommended for rulebook</span></strong>
          <small>Hybrid (BM25 + cosine) pulls 15 candidates; Claude Haiku picks the best 3. Handles citations AND concepts.</small>
        </span>
      </label>
    </fieldset>

    <button type="submit">Ask</button>
  <% end %>

  <h2>Try one of these:</h2>
  <ul class="sample-questions">
    <% [
      "How long is a minor penalty?",
      "How big is the goal crease?",
      "What's the difference between icing and offside?",
      "What does Rule 22.1 say?",
    ].each do |sample| %>
      <li>
        <button type="button" class="sample-question-link"
                data-action="click->sample-question#fill">
          <%= sample %>
        </button>
      </li>
    <% end %>
  </ul>
</div>
