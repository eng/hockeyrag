<% content_for :title, "Hockey Rules Q&A" %>

<%= turbo_stream_from @question, "answers" %>

<div class="page">
  <h1>Hockey Rules Q&amp;A</h1>
  <p class="question-text">
    <strong>Q:</strong> <%= @question.text %><br>
    <small class="muted">RAG using <%= @question.rag_strategy_label %>.</small>
  </p>
  <p><%= link_to "← Ask another", new_question_path %></p>

  <div class="three-panel">
    <% @question.answers.sort_by { |a| Answer::MODES.index(a.mode) }.each do |answer| %>
      <%= render "answers/panel", answer: answer, question: @question %>
    <% end %>
  </div>
</div>
